{
    "name": "@wovosoft/wovoui",
    "version": "1.2.23",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "preview": "vite preview",
        "build:post": "node post-process-dts.js",
        "build:package": "vite build",
        "build:types": "vue-tsc --declaration --emitDeclarationOnly && tsc-alias -p tsconfig.json",
        "build:production": "bun run build:package && bun run build:types",
        "generate:types": "node scripts/generate-component-types.js",
        "generate:ide": "node scripts/generate-ide-support.js",
        "generate:all": "bun run generate:types && bun run generate:ide"
    },
    "sideEffects": [
        "*.vue"
    ],
    "files": [
        "dist",
        "src"
    ],
    "types": "./dist/index.d.ts",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "web-types": "./web-types.json",
    "vetur": {
        "tags": "./vetur-tags.json",
        "attributes": "./vetur-attributes.json"
    },
    "peerDependencies": {
        "axios": "*",
        "chart.js": "^4.5.0",
        "vue": "^3.5.18",
        "prismjs": "^1.30.0",
        "dayjs": "^1.11.13",
        "bootstrap": "^5.3.7",
        "bootstrap-icons": "^1.13.1"
    },
    "dependencies": {
        "@popperjs/core": "^2.11.8",
        "@vueuse/components": "^13.6.0",
        "@vueuse/core": "^13.6.0",
        "@wovosoft/wovoui-icons": "^1.1.11",
        "axios": "^1.11.0",
        "lodash": "^4.17.21",
        "tsc-alias": "^1.8.16"
    },
    "devDependencies": {
        "@types/bootstrap": "^5.2.10",
        "@types/lodash": "^4.17.20",
        "@types/node": "^24.2.1",
        "@types/prismjs": "^1.26.5",
        "@vitejs/plugin-vue": "^6.0.1",
        "@wdns/vue-code-block": "^2.3.5",
        "sass": "^1.90.0",
        "typescript": "^5.9.2",
        "vite": "^7.1.2",
        "vue-router": "^4.5.1",
        "vue-tsc": "^3.0.5"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wovosoft/wovoui.git"
    },
    "bugs": {
        "url": "https://github.com/wovosoft/wovoui/issues"
    },
    "homepage": "https://github.com/wovosoft/wovoui#readme",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "license": "MIT",
    "exports": {
        "./dist/style.css": "./dist/style.css",
        "./types": "./dist/types/index.d.ts",
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/types/index.d.ts"
        },
